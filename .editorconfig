root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{ts,tsx,js,jsx,mjs,cjs,json,css,scss,html,yml,yaml}]
indent_size = 2

[*.sh]
indent_size = 2

[*.{xml,svg}]
indent_size = 2

[*.md]
indent_size = 4
trim_trailing_whitespace = false
